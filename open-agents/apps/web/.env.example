# Minimum runtime
POSTGRES_URL=
BETTER_AUTH_SECRET=

# Vercel OAuth (required for sign-in)
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github (better-auth)
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback (installation sync)
# In the GitHub App settings:
#   1. Use the GitHub App Client ID and Client Secret below
#   2. Make the app public if you want org installs to work cleanly
#   3. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=
RAWTREE_API_KEY=
AI_GATEWAY_API_KEY=
OPEN_AGENTS_LEADERBOARD_DOMAINS=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional Postgres tuning. The default is 3, which fits Supabase session pooler development.
POSTGRES_MAX_CONNECTIONS=

# Optional deployment refinements
# Set to "hobby" to use lower resource defaults for constrained deployments.
# Leave unset for standard behavior.
OPEN_AGENTS_RESOURCE_PROFILE=
# Set to "true" only when you want localhost to behave like the hosted demo.
OPEN_AGENTS_LOCAL_MANAGED_TEMPLATE_TRIAL=false
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
# Optional base snapshot for fresh sandboxes. If unset, sandboxes use Vercel's standard Sandbox runtime.
# Use a snapshot created in/accessible to your own Vercel scope.
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
